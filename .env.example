# MongoDB Connection
# MongoDB username for authentication
MONGO_USERNAME=<mongo_username>

# MongoDB password for authentication
MONGO_PASSWORD=<mongo_password>

# MongoDB connection URI
# You can either use MONGO_URI with embedded credentials or use the separate username/password fields
# Example with credentials: mongodb://username:password@localhost:27017
# Example without: mongodb://localhost:27017 (then use MONGO_USERNAME and MONGO_PASSWORD)
MONGO_URI=mongodb://localhost:27017

# MongoDB Database Name
# The name of the database to export data from
MONGO_DB=<mongo_database>
# Output Directory
# Directory where CSV export files will be saved
# If not provided, files will be saved with timestamp: export-YYYY-MM-DDTHH-mm-ss-sssZ.csv
OUTPUT_DIR=./output

# Logging
# Log level for application logs
# Options: trace, debug, info, warn, error, fatal
# Default: info
LOG_LEVEL=info
