{
  "name": "mongodb-csv-exporter",
  "version": "1.0.0",
  "description": "Node.js application that extracts time series sensor data from MongoDB and exports it to CSV files for machine learning training",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "lint": "eslint src tests --ext .ts"
  },
  "keywords": [
    "mongodb",
    "csv",
    "export",
    "timeseries",
    "machine-learning"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.5",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "csv-writer": "^1.6.0",
    "fast-check": "^3.15.1",
    "mongodb": "^6.3.0",
    "pino": "^8.17.2",
    "pino-pretty": "^13.1.3"
  }
}
